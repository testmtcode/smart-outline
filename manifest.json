{
  "manifest_version": 3,
  "name": "SmartOutline - 智能网页大纲",
  "version": "2.0.0",
  "description": "为任何网页自动生成目录大纲，支持搜索、复制、拖拽，悬浮导航一键跳转",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
